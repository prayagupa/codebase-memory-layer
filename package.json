{
  "name": "codebase-memory-layer",
  "displayName": "Codebase Memory Layer",
  "description": "Persistent, semantic codebase memory for GitHub Copilot — local-first vector index injected as chat context.",
  "version": "0.1.0",
  "publisher": "prayag",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["copilot", "memory", "embeddings", "semantic search", "rag"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Codebase Memory Layer",
      "properties": {
        "memory.include": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["**/*.{ts,js,tsx,jsx,py,go,java,md}"],
          "description": "Glob patterns of files to include in the memory index."
        },
        "memory.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["**/node_modules/**", "**/dist/**", "**/out/**", "**/.git/**"],
          "description": "Glob patterns of files to exclude from the memory index."
        },
        "memory.topK": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 32,
          "description": "Number of chunks to retrieve per query."
        },
        "memory.tokenBudget": {
          "type": "number",
          "default": 4096,
          "description": "Maximum tokens for injected codebase context."
        },
        "memory.embeddingModel": {
          "type": "string",
          "default": "nomic-embed-code",
          "description": "Embedding model key or path to a local .onnx file."
        },
        "memory.chunkOverlapTokens": {
          "type": "number",
          "default": 40,
          "description": "Token overlap used by the sliding-window fallback chunker."
        },
        "memory.secretPatternDetection": {
          "type": "boolean",
          "default": true,
          "description": "Exclude chunks that match common secret/API-key patterns."
        }
      }
    },
    "commands": [
      {
        "command": "codebaseMemory.reindex",
        "title": "Codebase Memory: Re-index Workspace"
      },
      {
        "command": "codebaseMemory.clearIndex",
        "title": "Codebase Memory: Clear Index"
      },
      {
        "command": "codebaseMemory.showStats",
        "title": "Codebase Memory: Show Index Stats"
      }
    ],
    "chatParticipants": [
      {
        "id": "memory.assistant",
        "name": "memory",
        "description": "Ask questions about your codebase — answers are grounded in a local semantic index.",
        "isSticky": false
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "ignore": "^5.3.1",
    "onnxruntime-node": "^1.18.0",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^9.5.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
